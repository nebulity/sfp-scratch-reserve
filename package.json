{
  "name": "sfp-scratch-reserve",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action to reserve and release pooled Salesforce scratch orgs.",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "ci": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "clean": "rm -rf dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^22.15.3",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.28.0",
    "vitest": "^3.0.9"
  }
}
